# Runtime
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Singapore
PUBLISH_MODE=dry-run

# Required for hosted D1 secret storage. Generate a long random value and set it
# only in the hosting platform's secret manager; never commit the real value.
MASTER_ENCRYPTION_KEY=

# AI provider (choose one later)
LLM_API_KEY=
LLM_MODEL=

# Paid enrichment
X_BEARER_TOKEN=

# Optional free/low-cost sources
GITHUB_TOKEN=
YOUTUBE_API_KEY=
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
ONCHAIN_RPC_URL=
EXCHANGE_ANNOUNCEMENT_FEEDS=

# Binance Square: one environment variable per authorized creator account
BINANCE_SQUARE_API_KEY_FLASH=
BINANCE_SQUARE_API_KEY_MARKET=
BINANCE_SQUARE_API_KEY_ONCHAIN=
BINANCE_SQUARE_API_KEY_RESEARCH=

# Future hosted infrastructure
DATABASE_URL=
OBJECT_STORAGE_BUCKET=
QUEUE_URL=
SENTRY_DSN=
